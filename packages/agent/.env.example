# WebSocket URL of the relay server. The agent connects here on startup.
# If self-hosting, replace with your own Railway/Fly/etc deployment URL.
RELAY_WS_URL=wss://runafk-relay-production.up.railway.app/agent

# A secret token that identifies this agent to the relay.
# Choose any strong random string (e.g. openssl rand -hex 32).
# Register it in Slack with /register <token> before starting the agent.
AGENT_TOKEN=your-secret-agent-token

# GitHub Personal Access Token with `repo` scope.
# Used to clone the repo, push branches, create PRs, and read issues.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token

# The GitHub repository this agent will work on, in owner/repo format.
# The GITHUB_TOKEN must have access to this repo.
AGENT_REPO=owner/repo

# Anthropic API key — passed to the Claude Code CLI for LLM calls.
# Create one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key
